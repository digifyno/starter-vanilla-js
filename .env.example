# Copy this file to .env.local for local development
# Variables must be prefixed with VITE_ to be accessible in browser code
# WARNING: All VITE_ variables are embedded in the built JS bundle — never put secrets here

# Example: API base URL (access via import.meta.env.VITE_API_URL)
# VITE_API_URL=https://api.example.com

# Example: Feature flag
# VITE_ENABLE_FEATURE_X=true

# Non-prefixed variables are NOT available in the browser:
# SECRET_KEY=server-only-value  ← this would be undefined in browser code
